{
  "Resources": {
    "SharedDataBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": "shared-data"
      }
    },
    "SharedDataBucketPolicy": {
      "Type": "AWS::S3::BucketPolicy",
      "Properties": {
        "Bucket": {
          "Ref": "SharedDataBucket"
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::999988887777:root"
              },
              "Action": "s3:GetObject",
              "Resource": "arn:aws:s3:::shared-data/*"
            }
          ]
        }
      }
    }
  }
}
